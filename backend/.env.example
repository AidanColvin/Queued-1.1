# NextWatch backend configuration. Copy to `.env` for local dev (it's gitignored).
# Everything here has a safe default in config.py — you only need to set values
# to override them.

# --- Core ---
# SQLAlchemy URL. Local dev defaults to a SQLite file. For production accounts
# use a persistent Postgres (Neon / Render / Supabase), pooled endpoint:
#   DATABASE_URL=postgresql+psycopg://USER:PASS@HOST/DB
DATABASE_URL=sqlite:///./nextwatch.db
# Comma-separated origins allowed to call the API with credentials.
CORS_ORIGINS=http://localhost:3000
# Optional TMDB key (trailers/search enrichment); the keyless paths work without it.
# TMDB_API_KEY=

# --- Accounts / auth (Phase 3) ---
# Secret that signs the session JWT. CHANGE THIS in production.
JWT_SECRET=dev-insecure-change-me
# Send the auth cookie with the Secure flag (true only over HTTPS).
COOKIE_SECURE=false
# SPA origin the Google OAuth callback redirects back to.
FRONTEND_URL=http://localhost:3000
# Google OAuth client (Google Cloud Console → Credentials → OAuth client, Web).
# Leave unset to disable "Continue with Google" (email/password still works).
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
