# ---- TMDB ----
# Free API key from https://www.themoviedb.org/settings/api
# Required ONLY for the real data pipeline (download.py / preprocess.py) and
# optional live /search enrichment. The bundled sample pipeline needs no key.
TMDB_API_KEY=your_key_here

# ---- Database ----
# SQLite for local dev. Swap to Postgres for prod with a single value change:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/queued
DATABASE_URL=sqlite:///./queued.db

# ---- ML artifacts ----
# Directory holding the model artifacts loaded at startup (movie_index.json,
# cf_item_factors.npy, tfidf_matrix.npz, embeddings.npy).
MODEL_ARTIFACTS_PATH=./data/artifacts

# ---- CORS ----
# Comma-separated origins allowed to call the API (the Next.js frontend).
CORS_ORIGINS=http://localhost:3000,https://queued-2.vercel.app

# ---- Sign in with Apple (native iOS builds) ----
# Comma-separated bundle ids / Services IDs accepted as the token audience.
# Unset -> POST /auth/apple reports 503 (web-only deployments don't need it).
# APPLE_CLIENT_IDS=com.queued.app

# ---- Transactional email (verification + password reset) ----
# SMTP credentials. Leave EMAIL_HOST unset in dev — outgoing mail is logged to
# the server console instead of being sent.
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USERNAME=apikey
# EMAIL_PASSWORD=secret
# EMAIL_FROM=Queued <no-reply@queued.app>

# ---- Abuse protection ----
# Per-IP rate limiting on auth endpoints. Leave on outside of tests.
RATE_LIMIT_ENABLED=true

# ---- Dev convenience ----
# When true, the backend auto-generates the bundled sample artifacts on startup
# if none are found, so `uvicorn main:app` works with zero data setup.
AUTO_SAMPLE=true
