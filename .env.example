# ---- TMDB ----
# Free API key from https://www.themoviedb.org/settings/api
# Required ONLY for the real data pipeline (download.py / preprocess.py) and
# optional live /search enrichment. The bundled sample pipeline needs no key.
TMDB_API_KEY=your_key_here

# ---- Database ----
# SQLite for local dev. Swap to Postgres for prod with a single value change:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/nextwatch
DATABASE_URL=sqlite:///./nextwatch.db

# ---- ML artifacts ----
# Directory holding the model artifacts loaded at startup (movie_index.json,
# cf_item_factors.npy, tfidf_matrix.npz, embeddings.npy).
MODEL_ARTIFACTS_PATH=./data/artifacts

# ---- CORS ----
# Comma-separated origins allowed to call the API (the Next.js frontend).
CORS_ORIGINS=http://localhost:3000,https://nextwatch.vercel.app

# ---- Dev convenience ----
# When true, the backend auto-generates the bundled sample artifacts on startup
# if none are found, so `uvicorn main:app` works with zero data setup.
AUTO_SAMPLE=true
