# ---- ML artifacts & raw data ----
# Generated/large artifacts are not committed. The sample artifacts are
# regenerated on demand via `python -m data.sample`; the real artifacts come
# from the download + preprocess pipeline.
backend/data/artifacts/*
!backend/data/artifacts/.gitkeep
backend/data/raw/
*.npy
*.npz
*.pkl

# ---- Node / Next.js (Phase 2) ----
node_modules/
.next/
out/
*.tsbuildinfo
frontend/.env*.local

# ---- OS / editor ----
.DS_Store
.idea/
.vscode/
*.swp

# ---- Local-only Claude Code settings (keep launch.json shareable) ----
.claude/settings.local.json

# ---- Committed servable model artifacts ----
# The trained 5,400-movie model ships in the repo so the deployed backend serves
# it out of the box. The 15 MB training parquet + raw data stay ignored above.
!backend/data/artifacts/movie_index.json
!backend/data/artifacts/cf_item_factors.npy
!backend/data/artifacts/tfidf_matrix.npz
!backend/data/artifacts/embeddings.npy
!backend/data/artifacts/tv_index.json
artifacts.backup*
backend/data/artifacts.backup*
